# Supabase
# - Local: from `supabase status` after `supabase start`
# - Hosted: from Supabase dashboard → Project Settings → API (URL, anon key, service_role key)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>
SUPABASE_SERVICE_ROLE_KEY=<service_role key>

# OpenAI (for real generation; required to run a session)
OPENAI_API_KEY=<your OpenAI API key>
# Optional: one model for everything (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Optional: different models per use (override OPENAI_MODEL when set)
# Cheaper for text (chat, critique); stronger for session artifact generation (and future image generation)
# OPENAI_MODEL_CHAT=gpt-4o-mini
# OPENAI_MODEL_CRITIQUE=gpt-4o-mini
# OPENAI_MODEL_GENERATION=gpt-4o
# Concept (session with preferMedium: "concept" / reflect mode); e.g. gpt-5-nano for cheaper concept artifacts.
# OPENAI_MODEL_CONCEPT=gpt-5-nano
# Image generation (session with preferMedium: "image"); default gpt-5-nano. For OpenAI use dall-e-3 or dall-e-2.
# OPENAI_MODEL_IMAGE=gpt-5-nano
